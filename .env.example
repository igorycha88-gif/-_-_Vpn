# SmartTraffic — переменные окружения
# Скопируйте в .env и заполните значения

# === Приложение ===
APP_PORT=8080

# === JWT ===
JWT_SECRET=change-me-to-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# === WireGuard ===
WG_INTERFACE=wg0
WG_PORT=51820
WG_CLIENT_SUBNET=10.10.0.0/24
WG_TUNNEL_SUBNET=10.20.0.0/30

# === Зарубежный сервер ===
FOREIGN_SERVER_IP=
FOREIGN_SERVER_WG_PORT=51821
FOREIGN_SERVER_PUBLIC_KEY=
FOREIGN_TUNNEL_PRIVATE_KEY=
FOREIGN_TUNNEL_PEER_PUBLIC_KEY=
FOREIGN_TUNNEL_LOCAL_ADDRESS=10.20.0.2/30

# === sing-box ===
SINGBOX_CONFIG_PATH=/etc/singbox/config.json

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Nginx / SSL ===
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# === Frontend ===
VITE_API_URL=http://localhost:8080
