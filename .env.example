# SmartTraffic — переменные окружения
# Скопируйте в .env и заполните значения

# === Приложение ===
APP_PORT=8080

# === JWT ===
JWT_SECRET=change-me-to-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# === VLESS+Reality (клиентские подключения) ===
VLESS_PRIVATE_KEY=your-reality-private-key-here
VLESS_PUBLIC_KEY=your-reality-public-key-here
VLESS_SHORT_ID=your-short-id-here
VLESS_SERVER_NAME=www.microsoft.com
VLESS_PORT=443
VLESS_FLOW=xtls-rprx-vision
VLESS_FINGERPRINT=chrome
VLESS_SERVER_ENDPOINT=your-server-ip-or-domain

# === WireGuard (межсерверный тоннель РФ ↔ Зарубежный) ===
WG_TUNNEL_INTERFACE=wg1

# === Зарубежный сервер ===
FOREIGN_SERVER_IP=
FOREIGN_TUNNEL_PRIVATE_KEY=
FOREIGN_TUNNEL_PEER_PUBLIC_KEY=
FOREIGN_TUNNEL_LOCAL_ADDRESS=10.20.0.2/30

# === Foreign VLESS relay (зарубежный sing-box) ===
FOREIGN_VLESS_UUID=
FOREIGN_VLESS_REALITY_PUBLIC_KEY=
FOREIGN_VLESS_REALITY_SHORT_ID=
FOREIGN_VLESS_SERVER_NAME=www.microsoft.com

# === sing-box ===
SINGBOX_CONFIG_PATH=/etc/singbox/config.json
SINGBOX_CLASH_API_ADDR=127.0.0.1:9090
SINGBOX_CLASH_API_SECRET=

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Nginx / SSL ===
DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com

# === Frontend ===
VITE_API_URL=http://localhost:8080
